# 给 bot 调用 controller 的地址
CONTROLLER_URL=http://127.0.0.1:8080

# 对外访问 controller 的地址（可选，给节点/外部使用）
CONTROLLER_PUBLIC_URL=http://your-public-ip:8080

# Bot 订阅链接基础地址（建议使用域名）
PANEL_BASE_URL=https://panel.example.com

# 是否启用 Caddy HTTPS（1=启用，0=关闭）
ENABLE_HTTPS=1

# Caddy 证书域名（启用 HTTPS 时使用）
HTTPS_DOMAIN=panel.example.com

# Caddy ACME 账号邮箱（可选，建议填写）
HTTPS_ACME_EMAIL=admin@example.com

# controller 监听端口
CONTROLLER_PORT=8080

# 轻量鉴权 token（留空=关闭接口鉴权；非空时除 /health、/sub/*、文档页外都需 Bearer）
AUTH_TOKEN=change_me_to_a_random_token

# 是否信任 X-Forwarded-For（默认 0；仅在有反向代理且配置可信代理 IP 时开启）
TRUST_X_FORWARDED_FOR=0

# 可信代理源 IP（逗号分隔；仅 TRUST_X_FORWARDED_FOR=1 时生效）
TRUSTED_PROXY_IPS=127.0.0.1,::1

# 节点任务运行超时秒数（超时后自动重试/标记超时）
NODE_TASK_RUNNING_TIMEOUT=120

# 节点任务历史保留秒数（到期自动清理）
NODE_TASK_RETENTION_SECONDS=604800

# 订阅签名密钥（可选；留空=关闭签名。建议设置随机长串）
SUB_LINK_SIGN_KEY=

# 是否强制订阅必须带签名（1=强制，0=允许无签名兼容）
SUB_LINK_REQUIRE_SIGNATURE=0

# 默认签名有效期（秒，默认 7 天）
SUB_LINK_DEFAULT_TTL_SECONDS=604800

# 轻量限流开关（1=开启，0=关闭；默认关闭）
API_RATE_LIMIT_ENABLED=0

# 限流窗口秒数（开启限流时生效）
API_RATE_LIMIT_WINDOW_SECONDS=60

# 单个 IP+路径 在窗口内的最大请求数（开启限流时生效）
API_RATE_LIMIT_MAX_REQUESTS=120

# Telegram Bot token（必填）
BOT_TOKEN=xxxxxxxx

# 管理员 chat id，逗号分隔，可空
ADMIN_CHAT_IDS=123,456

# 可选：只读管理员 chat id（逗号分隔）
VIEW_ADMIN_CHAT_IDS=

# 可选：运维管理员 chat id（逗号分隔；可执行创建/修改/分配等写操作）
OPS_ADMIN_CHAT_IDS=

# 可选：超级管理员 chat id（逗号分隔；可执行删除/迁移导入/远程运维高危操作）
SUPER_ADMIN_CHAT_IDS=

# 迁移包目录（默认）
MIGRATE_DIR=/var/backups/sb-migrate

# 控制器备份保留数量（超出自动清理）
BACKUP_RETENTION_COUNT=30

# 迁移包保留数量（超出自动清理）
MIGRATE_RETENTION_COUNT=20

# Bot 菜单按钮自动清理秒数（可选）
BOT_MENU_TTL=60

# 节点在线检测周期秒数（可选）
BOT_NODE_MONITOR_INTERVAL=60

# 节点离线判定阈值秒数（可选）
BOT_NODE_OFFLINE_THRESHOLD=120

# bot -> controller 请求超时时间（秒）
CONTROLLER_HTTP_TIMEOUT=10

# bot 调 controller 时附带的操作者标识（用于审计）
BOT_ACTOR_LABEL=sb-bot

# 日志翻页冷却秒数（可选，防止频繁点击触发 Telegram 限流）
BOT_LOG_VIEW_COOLDOWN=1

# Bot 写操作按钮防抖秒数（可选，防止重复点击导致重复执行）
BOT_MUTATION_COOLDOWN=1

# 日志查看最大页数（可选，超出后请在服务器用 journalctl 看全量）
BOT_LOG_VIEW_MAX_PAGES=100
