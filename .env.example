# 给 bot 调用 controller 的地址
CONTROLLER_URL=http://127.0.0.1:8080

# 对外访问 controller 的地址（可选，给节点/外部使用）
CONTROLLER_PUBLIC_URL=http://your-public-ip:8080

# Bot 订阅链接基础地址（建议使用域名）
PANEL_BASE_URL=https://panel.example.com

# controller 监听端口
CONTROLLER_PORT=8080

# 轻量鉴权 token（留空=关闭 /admin/* 鉴权）
AUTH_TOKEN=devtoken123

# Telegram Bot token（必填）
BOT_TOKEN=xxxxxxxx

# 管理员 chat id，逗号分隔，可空
ADMIN_CHAT_IDS=123,456

# 迁移包目录（默认）
MIGRATE_DIR=/var/backups/sb-migrate

# Bot 菜单按钮自动清理秒数（可选）
BOT_MENU_TTL=60

# 节点在线检测周期秒数（可选）
BOT_NODE_MONITOR_INTERVAL=60

# 节点离线判定阈值秒数（可选）
BOT_NODE_OFFLINE_THRESHOLD=120
